          { "name": "values", "items": [
            { "jaql": { "dim": "[Orders.Revenue]", "agg": "sum", "title": "Total Revenue" },
              "format": { "mask": { "type": "number", "decimals": 0 } } }
          ] },
          { "name": "break by", "items": [] },
          { "name": "filters", "items": [] }
        ]
      }
    },
    {

      "type": "indicator",
      "subtype": "indicator/numeric",
      "title": "Avg Order Value",
      "metadata": {
        "panels": [
          { "name": "values", "items": [
            { "jaql": { "formula": "sum([rev]) / count([ord])",
                        "context": {
                          "[rev]": { "dim": "[Orders.Revenue]", "agg": "sum" },
                          "[ord]": { "dim": "[Orders.Order ID]", "agg": "count" }
